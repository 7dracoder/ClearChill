# Supabase Configuration (REQUIRED for deployment)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI API Keys (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
K2_API_KEY=your_k2_api_key_here

# Inference mode for Pi: "gemini" (default), "yolo", or "hybrid"
# - gemini: Slow but accurate, reads expiry dates from labels, API costs
# - yolo:   Fast local inference, bbox tracking, no expiry reading, no API costs
# - hybrid: YOLO for tracking + Gemini for expiry dates (best of both)
INFERENCE_MODE=gemini

# YOLO ONNX configuration (only needed if INFERENCE_MODE=yolo or hybrid)
YOLO_MODEL_PATH=/data/models/yolov8n.onnx
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.5

# Image Generation (REQUIRED)
REPLICATE_API_TOKEN=your_replicate_token_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production

# Security (REQUIRED - generate with: openssl rand -hex 32)
SECRET_KEY=generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=https://yourdomain.com,http://YOUR_DROPLET_IP

# Database (SQLite - default, no configuration needed)
# Database file will be created as fridge.db in project root
# For custom location, set: FRIDGE_DB_PATH=/path/to/database.db

# Hardware Configuration (for Raspberry Pi sensor script)
API_BASE_URL=http://localhost:8000
API_TOKEN=your_jwt_token_here

# RC timing light sensor — physical BOARD pin number (pin 7 = GPIO4 by default)
LIGHT_SENSOR_PIN=7

# Darkness threshold in milliseconds (RC charge time).
# Run raspberry_pi_sensor.py and watch the printed values to calibrate:
#   Door open  (bright): typically  0.5 – 5 ms
#   Door closed (dark):  typically 20  – 200 ms
# Set DARK_THRESHOLD between those two ranges.
DARK_THRESHOLD=80.0

CAPTURE_DELAY=2.0
CAPTURE_COOLDOWN=30.0
CAPTURE_FPS=1.0
WEBCAM_INDEX=0
# Minimum confidence (0.0–1.0) for Gemini to report an item. Lower = more items but more false positives.
CONFIDENCE_THRESHOLD=0.75

# Pi SSH connection (for run_camera.py — used on your dev machine, not the Pi)
PI_HOST=192.168.0.1
PI_USER=pi
PI_PASSWORD=                        # leave blank if using key-based auth
PI_SSH_KEY=~/.ssh/id_rsa            # path to private key (preferred over password)
PI_VENV=/data/venv
PI_APP_DIR=/data/pi             # pi/ subfolder on the device
CAMERA_PORT=8001
